# Local Trino + supporting services
TRINO_PORT=8080
HIVE_METASTORE_PORT=9083
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432

# Source for `extract-replay-data.py` (run once, output is committed)
GOLDEN_DATASET_PATH=../atlan-trino-app/new-golden-dataset

# Synthetic generator knobs — tune to land at ~10-15k assets total
SYNTHETIC_BASELINE_SCHEMAS=5
SYNTHETIC_BASELINE_TABLES_PER_SCHEMA=12
SYNTHETIC_BASELINE_COLUMNS_PER_TABLE=70
SYNTHETIC_LINEAGE_VIEWS=10
ENABLE_SYNTHETIC=true

# Replay knobs
REPLAY_PRIMARY_CATALOG=analytics
ENABLE_SECONDARY_CATALOGS=false   # set true to populate `events` and `archive`

# Cloudflare Tunnel — exposes Trino on a public hostname for tenant testing.
# Create via Cloudflare Zero Trust dashboard → Networks → Tunnels.
# Set the tunnel's Public Hostname to point at http://trino:8080
# Uncomment to enable; start with: docker compose --profile tunnel up -d cloudflared
# CLOUDFLARED_TOKEN=your-tunnel-token-here
